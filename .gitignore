# ─────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pdb
*.egg-info/
dist/
build/
*.egg

# ─────────────────────────────────────────────────────────────────────
# Ambiente Virtual
# ─────────────────────────────────────────────────────────────────────
venv/
.venv/
env/

# ─────────────────────────────────────────────────────────────────────
# Arquivos de Ambiente e Segredos (NUNCA subir para o Git!)
# ─────────────────────────────────────────────────────────────────────
.env
*.env.*
!.env.example

# ─────────────────────────────────────────────────────────────────────
# Banco de Dados Local (Gerado automaticamente pelo app na primeira run)
# ─────────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ─────────────────────────────────────────────────────────────────────
# Banco de Dados Vetorial (Qdrant — dados locais em disco)
# Estes dados são pesados e recriados via bulk_upload.py
# ─────────────────────────────────────────────────────────────────────
qdrant_data/

# ─────────────────────────────────────────────────────────────────────
# Documentos Convertidos (São gerados via scripts/convert_docs.py)
# Pesados demais para versionar no Git
# ─────────────────────────────────────────────────────────────────────
documents/

# ─────────────────────────────────────────────────────────────────────
# Instaladores e Binários
# ─────────────────────────────────────────────────────────────────────
*.msi
*.exe
*.zip
*.tar.gz

# ─────────────────────────────────────────────────────────────────────
# IDEs e Editores
# ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ─────────────────────────────────────────────────────────────────────
# Sistema Operacional
# ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
