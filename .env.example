# Google Gemini API Credentials
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash


# Database Settings (SQLite local for MVP)
DATABASE_URL=sqlite:///./app.db

# Qdrant Settings (Leave empty for in-memory, specify path for local disk storage, or URL for Docker/Cloud Qdrant)
# For in-memory (loses data on restart): use :memory:
# For local disk storage: use ./qdrant_data
# For docker/cloud server: use http://localhost:6333
QDRANT_PATH=./qdrant_data
QDRANT_URL=

# Application Settings
HOST=0.0.0.0
PORT=8000
DEBUG=True
